<Window x:Class="SimpleCSVEditorByWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleCSVEditorByWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DockPanel>
            <!-- 上部：タイトルエリア -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
                <Label Content="CSV読み込みくん" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 下部：ボタンエリア -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" 
            HorizontalAlignment="Right" Margin="10">
                <Button Content="保存" Width="80" Margin="5" Click="SaveCsvFileButton_Click"/>
            </StackPanel>

            <!-- 中央：メモエリア -->
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBox x:Name="CsvFilePathTextBox" AcceptsReturn="True" Margin="5" TextWrapping="Wrap" Width="585"/>
                    <Button Content="ファイル選択" Width="80" Margin="5" Click="SelectFileButton_Click"/>
                    <Button Content="ファイル読込" Width="80" Margin="5" Click="LoadCevFileButton_Click"/>
                </StackPanel>

                <DataGrid Grid.Row="1" Name="CsvDataGridView" AutoGenerateColumns="True" ColumnWidth="*" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn"/>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
