<Window x:Class="SimpleCSVEditorByWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleCSVEditorByWPF"
        xmlns:views="clr-namespace:SimpleCSVEditorByWPF.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
                <Label Content="CSV読み込みくん" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <views:CsvFileReadView x:Name="CsvFileReadView" Grid.Row="0"/>
                <views:CsvEditorView x:Name="CsvEditorView" Grid.Row="1"/>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
